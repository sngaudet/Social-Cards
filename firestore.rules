rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function pairId(uid1, uid2) {
      return uid1 < uid2 ? uid1 + "_" + uid2 : uid2 + "_" + uid1;
    }

    function relationshipPath(uid1, uid2) {
      return /databases/$(database)/documents/relationships/$(pairId(uid1, uid2));
    }

    function relationshipStatus(uid1, uid2) {
      let path = relationshipPath(uid1, uid2);
      return exists(path) ? get(path).data.status : "none";
    }

    function canReadPublicProfile(userId) {
      let status = relationshipStatus(request.auth.uid, userId);
      return request.auth.uid == userId
        || (
          status != "declined"
          && status != "blocked"
        );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;

      match /devices/{deviceId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn() && canReadPublicProfile(userId);
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /relationships/{relationshipId} {
      allow create: if signedIn()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] is string
        && request.resource.data.users[1] is string
        && request.resource.data.users[0] != request.resource.data.users[1]
        && relationshipId == pairId(
          request.resource.data.users[0],
          request.resource.data.users[1],
        )
        && request.resource.data.users.hasAny([request.auth.uid])
        && (
          request.resource.data.status == "pending"
          || request.resource.data.status == "accepted"
          || request.resource.data.status == "declined"
          || request.resource.data.status == "blocked"
        );

      allow read: if signedIn() && resource.data.users.hasAny([request.auth.uid]);

      allow update: if signedIn()
        && resource.data.users is list
        && resource.data.users.hasAny([request.auth.uid])
        && request.resource.data.users == resource.data.users
        && request.resource.data.users.size() == 2
        && relationshipId == pairId(
          request.resource.data.users[0],
          request.resource.data.users[1],
        )
        && (
          request.resource.data.status == "pending"
          || request.resource.data.status == "accepted"
          || request.resource.data.status == "declined"
          || request.resource.data.status == "blocked"
        );

      allow delete: if false;
    }

    match /connectionRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == "pending";

      allow read: if signedIn()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );

      allow update: if signedIn()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        )
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && (
          request.resource.data.status == "accepted"
          || request.resource.data.status == "declined"
        );

      allow delete: if false;
    }

    match /connections/{connectionId} {
      allow create: if signedIn()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] is string
        && request.resource.data.users[1] is string
        && request.resource.data.users[0] != request.resource.data.users[1]
        && request.resource.data.users.hasAny([request.auth.uid]);

      allow read: if signedIn() && resource.data.users.hasAny([request.auth.uid]);
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/connections/$(connectionId))
            .data.users.hasAny([request.auth.uid]);

        allow create: if signedIn()
          && get(/databases/$(database)/documents/connections/$(connectionId))
            .data.users.hasAny([request.auth.uid])
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update, delete: if false;
      }
    }

    match /presence/{docId} {
      allow read, write: if false;
    }

    match /notificationState/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
